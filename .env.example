# main.py loads this .env file.
# Generate a token at https://github.com/settings/tokens
#   read:user    -> harvest (read public follower lists)
#   user:follow  -> follow / unfollow on your account
# A classic token needs both scopes; a fine-grained token needs the
# "Followers" user permission set to Read & write.
GITHUB_TOKEN=ghp_xxxxyyyzzz1234567890abcdefg
